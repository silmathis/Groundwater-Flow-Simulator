{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Groundwater Streamlit App",
      "type": "python",
      "request": "launch",
      "module": "streamlit",
      "args": [
        "run",
        "my_project/my_project/app.py"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "STREAMLIT_BROWSER_GATHER_USAGE_STATS": "false"
      }
    },
    {
      "name": "Python: app.py starten",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/my_project/my_project/app.py",
      "console": "integratedTerminal"
    }
  ]
}
